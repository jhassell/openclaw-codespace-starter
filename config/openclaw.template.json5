// OpenClaw configuration template.
// scripts/configure.sh renders this to ~/.openclaw/openclaw.json (JSON5),
// substituting the placeholder tokens below. Full reference:
//   https://docs.openclaw.ai/gateway/configuration
//
// NOTE: OpenClaw uses STRICT schema validation — unknown keys make the gateway
// refuse to start. Keep edits within documented fields.
{
  // Route every model call through the OU LiteLLM gateway (OpenAI-compatible API).
  models: {
    providers: {
      litellm: {
        baseUrl: "@@BASE_URL@@",
        // Resolved at load time from ~/.openclaw/.env (never hard-code the key here).
        apiKey: "${LITELLM_API_KEY}",
        api: "openai-completions",
        models: [
          {
            id: "@@MODEL_ID@@",
            name: "@@MODEL_NAME@@",
            // Adjust these to match the real model if needed.
            reasoning: false,
            input: ["text"],
            contextWindow: 128000,
            maxTokens: 8192,
          },
        ],
      },
    },
  },

  agents: {
    defaults: {
      model: { primary: "litellm/@@MODEL_ID@@" },
      workspace: "~/.openclaw/workspace",
    },
  },
}
