# OU LiteLLM credentials for OpenClaw.
#
# Easiest path: set this as a Codespaces secret named LITELLM_API_KEY
# (the Codespace will prompt you on creation). Then you can ignore this file.
#
# Otherwise, run `bash scripts/set-key.sh` and it will be written for you to
# ~/.openclaw/.env — do NOT commit your real key.
#
# Your OU LiteLLM key (starts with sk-):
LITELLM_API_KEY=sk-REPLACE_ME
